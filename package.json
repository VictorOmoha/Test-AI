{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=ai-test-app-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name ai-test-app",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply ai-test-app-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply ai-test-app-production",
    "db:seed": "wrangler d1 execute ai-test-app-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute ai-test-app-production --local",
    "db:console:prod": "wrangler d1 execute ai-test-app-production",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test:db": "curl http://localhost:3000/api/health"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250816.0",
    "@neondatabase/serverless": "^0.10.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.3.0",
    "@types/uuid": "^10.0.0",
    "hono": "^4.9.2",
    "typescript": "^5.9.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
